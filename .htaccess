# Updated for Next.js static export
# Begin

<Files "sendmail.php">
	Satisfy Any
	Order allow,deny
	Allow from all
</Files>

RewriteEngine on

# Enforce SSL
RewriteCond %{HTTPS} !=on
RewriteCond %{HTTP_HOST} ^(www\.)?vksozerkegem\.be [NC]
RewriteRule ^(.*) https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Serve directory index.html for clean URLs
# e.g. /ploegen/akern -> /ploegen/akern/index.html
RewriteCond %{REQUEST_METHOD} ^(GET|HEAD) [NC]
RewriteCond %{DOCUMENT_ROOT}%{REQUEST_URI}/index.html -f
RewriteRule ^(.*)$ $1/index.html [L]

# Fallback: try .html extension (for old files during migration)
RewriteCond %{REQUEST_METHOD} ^(GET|HEAD) [NC]
RewriteCond %{DOCUMENT_ROOT}%{REQUEST_URI}.html -f
RewriteRule ^(.*)$ $1.html [L]

# End
